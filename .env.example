# =============================================================================
# CheckinBliss — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# The app runs in mock mode with no credentials set.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Can use sb_publishable_... or legacy anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Can use sb_secret_... or legacy service_role key
SUPABASE_SECRET_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PK=

# --- Auth ---
AUTH_SECRET=

# --- Cron + Admin ---
CRON_SECRET=

# Founder-only gate for the admin dashboard and all admin mutations.
# In production: required. Admin routes (claims, operators, properties)
# and Server Actions return 401 / refuse to render when this is missing.
# In mock mode (no Supabase or Stripe keys, NODE_ENV != production):
# bypassed automatically so dev login keeps working.
# Pass via the x-admin-key request header or via /admin?admin_key=<key>
# to unlock the dashboard in a real browser.
ADMIN_DASH_KEY=

# --- WhatsApp Business (Meta Cloud API) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Mapbox GL JS (public token, URL-restricted in production) ---
# CRITICAL: This MUST be a PUBLIC token (prefix "pk."), NOT a secret token ("sk.").
# Secret tokens are for server-side API calls only and will be rejected by the
# Mapbox tile CDN when used client-side — the map will render as a blank canvas.
# Create one at https://account.mapbox.com/access-tokens/ → "Create a token".
# URL-restrict this token in the Mapbox dashboard to your production domain
# (e.g. checkinbliss.vercel.app) so it can't be reused elsewhere.
# The app shows a styled "Map unavailable" fallback when this is missing or invalid.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Airtable (property onboarding tracker) ---
AIRTABLE_BASE_ID=
AIRTABLE_TOKEN=
