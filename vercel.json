{
  "installCommand": "npm install --force",
  "crons": [
    {
      "path": "/api/cron/inspections",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/feedback",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reconcile",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sweep",
      "schedule": "0 */2 * * *"
    }
  ]
}
